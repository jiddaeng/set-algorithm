{
  "manifest_version": 3,
  "name": "Algorithm Package",
  "version": "1.0.5",

  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://www.youtube.com/*",
    "https://www.instagram.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.instagram.com/*"
      ],
      "js": [
        "packages.js",
        "classifier.js",
        "utils.js",
        "observer.js",
        "content.js",
        "reels.js"
      ]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}
